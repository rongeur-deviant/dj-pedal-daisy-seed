 217:../../libDaisy/src/dev/oled_ssd130x.h ****               | ((val & 0x40) >> 5) | ((val & 0x80) >> 7);
 218:../../libDaisy/src/dev/oled_ssd130x.h **** 
 219:../../libDaisy/src/dev/oled_ssd130x.h ****         for(uint8_t bit = 0u; bit < 8u; bit++)
 220:../../libDaisy/src/dev/oled_ssd130x.h ****         {
 221:../../libDaisy/src/dev/oled_ssd130x.h ****             dsy_gpio_write(&pin_mosi_, ((val & (1 << bit)) ? 1 : 0));
 222:../../libDaisy/src/dev/oled_ssd130x.h **** 
 223:../../libDaisy/src/dev/oled_ssd130x.h ****             System::DelayTicks(clk_delay);
 224:../../libDaisy/src/dev/oled_ssd130x.h **** 
 225:../../libDaisy/src/dev/oled_ssd130x.h ****             dsy_gpio_toggle(&pin_sclk_);
 226:../../libDaisy/src/dev/oled_ssd130x.h **** 
 227:../../libDaisy/src/dev/oled_ssd130x.h ****             System::DelayTicks(clk_delay);
 228:../../libDaisy/src/dev/oled_ssd130x.h **** 
 229:../../libDaisy/src/dev/oled_ssd130x.h ****             dsy_gpio_toggle(&pin_sclk_);
 230:../../libDaisy/src/dev/oled_ssd130x.h ****         }
 231:../../libDaisy/src/dev/oled_ssd130x.h ****     }
 232:../../libDaisy/src/dev/oled_ssd130x.h **** 
 233:../../libDaisy/src/dev/oled_ssd130x.h ****     uint32_t clk_delay;
